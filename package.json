{
  "name": "riz-bot",
  "version": "3.0.0",
  "private": true,
  "description": "Rizowski's discord server bot",
  "type": "module",
  "main": "src/index.js",
  "packageManager": "yarn@4.17.1",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "start": "node .",
    "local": "doppler run -c dev -- node --watch src/index.js",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "lefthook install"
  },
  "author": "Colten Rouska",
  "license": "MIT",
  "engines": {
    "node": ">=26"
  },
  "dependencies": {
    "@local/discord": "workspace:*",
    "@local/logger": "workspace:*",
    "@local/responses": "workspace:*",
    "config": "^4.4.2"
  },
  "devDependencies": {
    "lefthook": "^2.1.10",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "vitest": "^4.1.10"
  }
}
